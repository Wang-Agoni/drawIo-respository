        <UserObject label="&lt;div style=&quot;font-size: 1px&quot;&gt;&lt;font style=&quot;font-size:15.52px;font-family:思源黑体;color:#333333;direction:ltr;letter-spacing:0px;line-height:120%;opacity:1&quot;&gt;可达性算法&lt;/font&gt;&lt;/div&gt;" tags="Background" id="FVv7fWHgckqN2Psue60s-7">
